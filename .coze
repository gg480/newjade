[project]
requires = ["nodejs-24"]

[dev]
build = ["sh", "-c", "mkdir -p \"$PWD/db\" && pnpm install && DATABASE_URL=\"file:$PWD/db/custom.db\" npx prisma db push && DATABASE_URL=\"file:$PWD/db/custom.db\" npx tsx prisma/seed-base.ts && DATABASE_URL=\"file:$PWD/db/custom.db\" npx tsx prisma/seed-business.ts && echo DATABASE_URL=\"file:$PWD/db/custom.db\" > .env"]
run   = ["pnpm", "run", "dev"]

[deploy]
build = ["sh", "scripts/deploy-build.sh"]
run = ["pnpm", "run", "start"]
