[project]
requires = ["nodejs-24"]

[dev]
build = ["sh", "-c", "mkdir -p db && pnpm install && DATABASE_URL=file:./db/custom.db npx prisma db push --skip-generate"]
run = ["sh", "-c", "DATABASE_URL=file:./db/custom.db pnpm run dev"]

[deploy]
build = ["sh", "scripts/deploy-build.sh"]
run = ["pnpm", "run", "start"]
